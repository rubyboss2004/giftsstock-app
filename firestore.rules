service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "a03131013@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['name', 'quantity']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.quantity is number;
    }

    function isValidExchangeRecord(data) {
      return data.keys().hasAll(['handler', 'date', 'quantity', 'system', 'status']) &&
             data.handler is string && data.handler.size() > 0 &&
             data.date is string &&
             data.quantity is number &&
             data.system in ['birthday', 'points'] &&
             data.status in ['pending', 'confirmed'] &&
             (!('exchangeItem' in data) || (data.exchangeItem is string)) &&
             (!('imageUrl' in data) || (data.imageUrl is string));
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    match /exchange_records/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidExchangeRecord(request.resource.data);
      allow update, delete: if isAuthenticated();
    }
    
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
